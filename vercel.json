{
  "version": 2,
  "buildCommand": "npm install && cd client && npm install && npm run build && cd .. && ls -la client/build/ || echo 'WARNING: client/build not found'",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "client/build/**",
          "server/**",
          "public/**",
          ".env*"
        ],
        "excludeFiles": [
          "client/src/**",
          "client/node_modules/**",
          "node_modules/.cache/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/"
    },
    {
      "src": "/socket.io(.*)",
      "dest": "/"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}

