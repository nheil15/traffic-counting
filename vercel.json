{
  "version": 2,
  "buildCommand": "npm install && cd client && npm install && npm run build && cd .. && ls -la client/build/",
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "client/build/**",
          "server/**",
          "package.json",
          ".env*"
        ],
        "excludeFiles": [
          "client/src/**",
          "client/node_modules/**",
          "node_modules/.cache/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server/index.js"
    }
  ]
}

