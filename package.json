{
  "name": "traffic-counting-web",
  "version": "1.0.0",
  "description": "Real-time traffic counting system with web dashboard",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm start",
    "postinstall": "cd client && npm install && npm run build",
    "build": "npm run build:server && npm run build:client",
    "build:server": "echo 'Server ready for deployment'",
    "build:client": "cd client && npm run build",
    "start": "node server/index.js",
    "test": "jest",
    "lint": "eslint server/ client/src/",
    "deploy": "npm run build && npm start"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "body-parser": "^1.20.2",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "child_process": "^1.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "eslint": "^8.52.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
