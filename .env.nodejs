# Node.js Environment Configuration

# App Settings
NODE_ENV=development
PORT=5000

# Client Settings
CLIENT_URL=http://localhost:3000

# Python Backend Integration (optional)
USE_PYTHON_BACKEND=true
PYTHON_API_URL=http://localhost:5050

# Logging
LOG_LEVEL=info

# API Settings
API_TIMEOUT=30
MAX_CONNECTIONS=100

# CORS Settings
CORS_ORIGIN=*
